{
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "16.2.4",
    "node-pg-migrate": "8.0.4",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Treinando para curso.dev",
  "main": "index.js",
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@secretlint/secretlint-rule-preset-recommend": "12.2.0",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "15.2.10",
    "prettier": "3.8.3",
    "secretlint": "12.2.0"
  },
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migrate:up && next dev",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "test": "npm run services:up && npm run wait-for-postgres && concurrently -n next,jest --hide next -k --success command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "test:watch": "jest --watchAll --runInBand",
    "migrate:create": "node-pg-migrate -m infra/migrations create",
    "migrate:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "prepare": "husky",
    "commit": "cz",
    "secrect": "secretlint --init"
  },
  "author": "",
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*": [
      "secretlint"
    ]
  }
}
