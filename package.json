{
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "^14.2.35",
    "node-pg-migrate": "7.9.1",
    "pg": "8.20.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Treinando para curso.dev",
  "main": "index.js",
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.4",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "15.2.10",
    "prettier": "3.8.3",
    "secretlint": "^9.3.4"
  },
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && next dev",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k --success command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "prepare": "husky",
    "commit": "cz",
    "secrect": "secretlint .",
    "secret:init": "secretlint --init"
  },
  "author": "",
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*": [
      "secretlint"
    ]
  }
}
